{
  "name": "stayfinder-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test": "node --test test/*.test.js && .venv/bin/python -m unittest discover -s test -p '*.py'",
    "ai:pregenerate": "node scripts/pregenerate_review_summaries.mjs",
    "mobile:start": "npm --prefix mobile run start",
    "mobile:android": "npm --prefix mobile run android",
    "mobile:web": "npm --prefix mobile run web",
    "mobile:typecheck": "npm --prefix mobile run typecheck"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.14.1"
  }
}
